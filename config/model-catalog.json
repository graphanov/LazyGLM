    "zai": {
      "base_url": "https://api.z.ai/api/coding/paas/v4",
      "requires_key": true,
      "env_key": "LAZYGLM_API_KEY"
    },
    "ollama": {
      "base_url": "http://localhost:11434/v1",
      "requires_key": false,
      "env_key": null
    }
  }
