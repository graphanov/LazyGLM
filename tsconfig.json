{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
    "src/agent/adaptive-router.js",
    "src/agent/router.js",
    "src/agent/provider.js",
    "src/agent/runtime.js",
    "src/agent/tool-errors.js",
    "src/agent/tools.js"
  ],
  "exclude": ["node_modules", "test", "dist"]
}
